{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth/index.js" },
    { "source": "/api/auth", "destination": "/api/auth/index.js" },
    
    { "source": "/api/products/(.*)", "destination": "/api/products/index.py" },
    { "source": "/api/products", "destination": "/api/products/index.py" },
    
    { "source": "/api/orders/(.*)", "destination": "/api/orders/main.go" },
    { "source": "/api/orders", "destination": "/api/orders/main.go" },
    
    { "source": "/((?!api/).*)", "destination": "/frontend/$1" }
  ]
}